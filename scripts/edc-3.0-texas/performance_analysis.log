. foreach f in `files' {
  2.     * Skip district/state specific files and redundant school files if using the main yea
> r file
.     * We will use the main year files (e.g., edc-3.0-texas-2022.csv) and filter for DataLeve
> l=="School"
.     if strpos("`f'", "-district") > 0 | strpos("`f'", "-state") > 0 | strpos("`f'", "-school
> ") > 0 {
  3.         continue
  4.     }
  5.     
.     display "--- Importing `f' ---"
  6.     import delimited using "`f'", clear varnames(1)
  7.     
.     * Standardize variable names to lowercase to avoid case-sensitivity issues
.     rename *, lower
  8.     
.     * Clean up string variables for robust filtering
.     foreach v in datalevel gradelevel studentsubgroup {
  9.         capture confirm variable `v'
 10.         if _rc == 0 {
 11.             replace `v' = trim(itrim(`v'))
 12.         }
 13.     }
 14.     
.     * Keep school level data only
.     capture keep if lower(datalevel) == "school"
 15.     if _rc {
 16.         display as error "Warning: Could not filter by datalevel in `f'. Check variable n
> ames."
 17.         describe
 18.         continue
 19.     }
 20.     
.     * Focus on Grades 4 and 8 (using robust matching)
.     capture keep if inlist(upper(gradelevel), "G04", "G08")
 21.     
.     * Focus on All Students for consistency
.     capture keep if lower(studentsubgroup) == "all students"
 22.     
.     count
 23.     if r(N) == 0 {
 24.         display "Warning: No school-level G04/G08 'All Students' records found in `f'. Sk
> ipping."
 25.         continue
 26.     }
 27.     
.     * Select key variables (using lowercase)
.     local keyvars "schyear datalevel stateassignedschid schname assmtname subject gradelevel
>  studentsubgroup proficientorabove_percent"
 28.     foreach v in `keyvars' {
 29.         capture confirm variable `v'
 30.         if _rc {
 31.             display "Warning: Variable `v' not found in `f'. Creating empty placeholder."
 32.             gen `v' = ""
 33.         }
 34.     }
 35.     keep `keyvars'
 36.     
.     * Append to master
.     append using `master'
 37.     save `master', replace
 38. }
