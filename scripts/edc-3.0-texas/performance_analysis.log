. * 5. SUMMARY STATISTICS (By Subject)
. foreach sub in "ela" "math" {
  2.     display "****************************************************************"
  3.     display "SUMMARY STATISTICS: `sub'"
  4.     display "****************************************************************"
  5.     tabstat proficientorabove_percent if subject == "`sub'", by(redesign) s(mean sd n) fo
> rmat(%9.2f)
  6.     table (gradelevel) (redesign) if subject == "`sub'", statistic(mean proficientorabove
> _percent) nformat(%9.2f)
  7. }
