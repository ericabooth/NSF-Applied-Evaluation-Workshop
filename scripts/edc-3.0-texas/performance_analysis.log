. * 7. REGRESSION ANALYSIS (Subject-Specific)
. foreach sub in "ela" "math" {
  2.     display "****************************************************************"
  3.     display "REGRESSION ANALYSIS: `sub' (2021-2024)"
  4.     display "****************************************************************"
  5.     
.     * OLS with Grade controls
.     display "OLS Model: `sub'"
  6.     reg proficientorabove_percent redesign i.gradelevel_n if subject == "`sub'" & inrange
> (year, 2021, 2024), vce(cluster stateassignedschid)
  7.     
.     * School-Grade Fixed Effects: Within-cohort change
.     * We use panel_id instead of school ID to avoid 'repeated time values' 
.     xtset panel_id year
  8.     display "Fixed Effects Model: `sub'"
  9.     xtreg proficientorabove_percent redesign if subject == "`sub'" & inrange(year, 2021, 
> 2024), fe vce(cluster stateassignedschid)
 10. }
